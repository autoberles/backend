  "components": {
    "schemas": {
      "AdditionalEquipment": {
        "required": [
          "air_conditioning_id",
          "heated_seats",
          "leather_seats",
          "navigation",
          "parking_sensors",
          "tempomat"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "car_id": {
            "type": "integer",
            "format": "int32"
          },
          "parking_sensors": {
            "type": "boolean"
          },
          "air_conditioning_id": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "heated_seats": {
            "type": "boolean"
          },
          "navigation": {
            "type": "boolean"
          },
          "leather_seats": {
            "type": "boolean"
          },
          "tempomat": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "Branch": {
        "required": [
          "address",
          "city",
          "email",
          "phone_number"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "city": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "address": {
            "maxLength": 255,
            "minLength": 5,
            "type": "string"
          },
          "email": {
            "maxLength": 150,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "phone_number": {
            "minLength": 1,
            "pattern": "^\\+36\\s\\d{2}\\s\\d{3}\\s\\d{3}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Car": {
        "required": [
          "availability",
          "brand",
          "color",
          "cubic_capacity",
          "img_url",
          "inspection_expiry_date",
          "last_service_date",
          "license_plate",
          "luggage_capacity",
          "mileage",
          "model",
          "number_of_doors",
          "number_of_seats",
          "own_weight",
          "performance_hp",
          "performance_kw",
          "price",
          "total_weight",
          "year"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "availability": {
            "type": "boolean"
          },
          "brand": {
            "maxLength": 50,
            "minLength": 2,
            "type": "string"
          },
          "model": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "year": {
            "maximum": 2100,
            "minimum": 1980,
            "type": "integer",
            "format": "int32"
          },
          "color": {
            "minLength": 1,
            "type": "string"
          },
          "own_weight": {
            "type": "integer",
            "format": "int32"
          },
          "total_weight": {
            "type": "integer",
            "format": "int32"
          },
          "number_of_seats": {
            "maximum": 9,
            "minimum": 2,
            "type": "integer",
            "format": "int32"
          },
          "number_of_doors": {
            "maximum": 5,
            "minimum": 2,
            "type": "integer",
            "format": "int32"
          },
          "price": {
            "type": "integer",
            "format": "int32"
          },
          "license_plate": {
            "minLength": 1,
            "pattern": "^[A-Z]{2}-[A-Z]{2}-\\d{3}$",
            "type": "string"
          },
          "mileage": {
            "type": "integer",
            "format": "int32"
          },
          "luggage_capacity": {
            "type": "integer",
            "format": "int32"
          },
          "cubic_capacity": {
            "type": "integer",
            "format": "int32"
          },
          "tank_capacity": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "battery_capacity": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "performance_kw": {
            "type": "integer",
            "format": "int32"
          },
          "performance_hp": {
            "type": "integer",
            "format": "int32"
          },
          "last_service_date": {
            "type": "string",
            "format": "date"
          },
          "inspection_expiry_date": {
            "type": "string",
            "format": "date"
          },
          "branch_id": {
            "type": "integer",
            "format": "int32"
          },
          "transmission_id": {
            "type": "integer",
            "format": "int32"
          },
          "fuel_type_id": {
            "type": "integer",
            "format": "int32"
          },
          "wheel_drive_type_id": {
            "type": "integer",
            "format": "int32"
          },
          "car_category_id": {
            "type": "integer",
            "format": "int32"
          },
          "default_price_per_day": {
            "type": "integer",
            "format": "int32"
          },
          "img_url": {
            "minLength": 1,
            "type": "string"
          },
          "additional_equipment": {
            "$ref": "#/components/schemas/AdditionalEquipment"
          }
        },
        "additionalProperties": false
      },
      "CreateUser": {
        "required": [
          "birth_date",
          "confirm_password",
          "email",
          "first_name",
          "last_name",
          "password",
          "phone_number",
          "role"
        ],

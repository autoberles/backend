  "components": {
    "schemas": {
      "Branch": {
        "required": [
          "address",
          "city",
          "email",
          "phoneNumber"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "city": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "address": {
            "maxLength": 255,
            "minLength": 5,
            "type": "string"
          },
          "email": {
            "maxLength": 150,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateAdditionalEquipmentDto": {
        "type": "object",
        "properties": {
          "parkingSensors": {
            "type": "boolean"
          },
          "heatedSeats": {
            "type": "boolean"
          },
          "navigation": {
            "type": "boolean"
          },
          "leatherSeats": {
            "type": "boolean"
          },
          "airConditioningId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateCarDTO": {
        "type": "object",
        "properties": {
          "brand": {
            "type": "string",
            "nullable": true
          },
          "model": {
            "type": "string",
            "nullable": true
          },
          "year": {
            "type": "integer",
            "format": "int32"
          },
          "numberOfSeats": {
            "type": "integer",
            "format": "int32"
          },
          "price": {
            "type": "integer",
            "format": "int32"
          },
          "licensePlate": {
            "type": "string",
            "nullable": true
          },
          "branchId": {
            "type": "integer",
            "format": "int32"
          },
          "transmissionId": {
            "type": "integer",
            "format": "int32"
          },
          "fuelTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "additionalEquipment": {
            "$ref": "#/components/schemas/CreateAdditionalEquipmentDto"
          }
        },
        "additionalProperties": false
      },
      "CreateUserDto": {
        "required": [
          "email",
          "firstName",
          "lastName"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "birthDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "Rental": {
        "required": [
          "endDate",
          "startDate"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "carId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "userId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
